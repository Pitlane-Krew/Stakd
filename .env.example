# ─────────────────────────────────────────────
# STAKD — Environment Variables Reference
# Copy to .env.local for local development.
# Set these in Vercel → Project → Settings → Environment Variables for production.
# ─────────────────────────────────────────────

# ── Supabase (required) ───────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-side only — never expose to client

# ── App URL (required) ────────────────────────
# Used for generating absolute URLs (e.g. OG images, email links)
# Local: http://localhost:3000
# Production: https://your-app.vercel.app  (or your custom domain)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Beta Mode (required for beta launch) ──────
# Set to "true" to unlock all features for everyone and hide pricing UI.
# Set to "false" (or remove) to enable tier gating and Stripe.
NEXT_PUBLIC_BETA_MODE=true

# ── AI — Anthropic Claude (required) ─────────
# Used for: AI grading, image enhancement, deal analysis
# Found in: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your-key

# ── Maps — Mapbox (required) ──────────────────
# Used for: route planning, restock map, store locator
# Found in: https://account.mapbox.com → Access Tokens
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-public-token
MAPBOX_SECRET_TOKEN=sk.your-secret-token          # server-side only

# Map provider selector (leave as "mapbox" unless swapping provider)
NEXT_PUBLIC_MAP_PROVIDER=mapbox

# ── Price Data — eBay (optional for beta) ─────
# Used for: real-time eBay sold listing prices
# Found in: https://developer.ebay.com → Application Keys
EBAY_APP_ID=your-ebay-app-id

# ── Cron Security (required) ──────────────────
# A secret string used to authenticate Vercel cron job requests.
# Generate with: openssl rand -hex 32
# Must match the Authorization header Vercel sends to /api/cron/*
CRON_SECRET=generate-a-random-secret-here
